{
	"i18n": true,
	"type": "panel",
	"items": {
		"location": {
			"newLine": true,
			"type": "header",
			"text": "useSystemLocationOrSpecifyCoordinates",
			"size": 3,
			"xs": 12,
			"sm": 12,
			"md": 12,
			"lg": 12,
			"xl": 12
		},
		"useSystemLocation": {
			"newLine": true,
			"type": "checkbox",
			"label": "useSystemLocation",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"latitude": {
			"newLine": true,
			"type": "number",
			"label": "latitudeDegrees",
			"help": "latitudeHelp",
			"placeholder": "latitudePlaceholder",
			"min": -90,
			"max": 90,
			"step": 0.1,
			"validator": "data.useSystemLocation || (isFinite(Number(data.latitude)))",
			"validatorErrorText": "latitudeRequiredWhenSystemLocationDisabled",
			"validatorNoSaveOnError": true,
			"hidden": "data.useSystemLocation",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		},
		"longitude": {
			"newLine": false,
			"type": "number",
			"label": "longitudeDegrees",
			"help": "longitudeHelp",
			"placeholder": "longitudePlaceholder",
			"min": -180,
			"max": 180,
			"step": 0.1,
			"validator": "data.useSystemLocation || (isFinite(Number(data.longitude)))",
			"validatorErrorText": "longitudeRequiredWhenSystemLocationDisabled",
			"validatorNoSaveOnError": true,
			"hidden": "data.useSystemLocation",
			"xs": 12,
			"sm": 12,
			"md": 6,
			"lg": 4,
			"xl": 4
		}
	}
}
